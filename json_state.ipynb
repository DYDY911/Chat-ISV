    "import json\n",
    "import re\n",
    "from pathlib import Path\n",
    "import csv\n",
    "from collections import defaultdict\n",
    "\n",
    "# ================\n",
    "INPUT_DIR = Path(\"D:\\\\x\\\\x\\\\x\\\\x\\\\metadata_pdf\")          
    "PROCESSED_INDEX_JSON = Path(\"D:\\\\x\\\\x\\\\x\\\\x\\\\progress.json\")  #  [\"1_1999_71_chunk_9\", ...]\n",
    "OUTPUT_CSV = Path(\"D:\\\\x\\\\x\\\\x\\\\x\\\\processing_status.csv\")\n",
    "# ===================================\n",
    "\n",
    "CHUNK_PAT = re.compile(r\"^(?P<stem>.+?)_chunk_(?P<idx>\\d+)$\")\n",
    "\n",
    "def load_processed_ids(p: Path):\n",
    "\"\"\"Compatibility: Pure JSON list or JSONL (one JSON object per line containing doc_id)\"\"\"\n",
    "    if p.suffix.lower() == \".jsonl\":\n",
    "        stems = defaultdict(list)\n",
    "        with p.open(\"r\", encoding=\"utf-8\") as f:\n",
    "            for line in f:\n",
    "                line = line.strip()\n",
    "                if not line:\n",
    "                    continue\n",
    "                try:\n",
    "                    obj = json.loads(line)\n",
    "                except json.JSONDecodeError:\n",
    "                    continue\n",
    "                doc_id = obj.get(\"doc_id\") or obj.get(\"DOC_ID\") or obj.get(\"id\")\n",
    "                if not doc_id or not isinstance(doc_id, str):\n",
    "                    continue\n",
    "                m = CHUNK_PAT.match(doc_id)\n",
    "                if m:\n",
    "                    stems[m.group(\"stem\")].append(int(m.group(\"idx\")))\n",
    "        return stems\n",
    "\n",
    "    with p.open(\"r\", encoding=\"utf-8\") as f:\n",
    "        data = json.load(f)\n",
    "    stems = defaultdict(list)\n",
    "    for s in data:\n",
    "        if not isinstance(s, str):\n",
    "            continue\n",
    "        m = CHUNK_PAT.match(s)\n",
    "        if m:\n",
    "            stems[m.group(\"stem\")].append(int(m.group(\"idx\")))\n",
    "    return stems\n",
    "\n",
    "def main():\n",
    "    all_txt_stems = {fp.stem for fp in INPUT_DIR.glob(\"*.pdf\")}\n",
    "\n",
    "    processed = load_processed_ids(PROCESSED_INDEX_JSON)\n",
    "    processed_stems = set(processed.keys())\n",
    "\n",
    "    already = sorted(all_txt_stems & processed_stems)\n",
    "    notyet  = sorted(all_txt_stems - processed_stems)\n",
    "\n",
"    print(f\"Total TXTs: {len(all_txt_stems)}\")\n",
    "    print(f\"Processed TXTs: {len(already)}\")\n",
    "    print(f\"Unprocessed TXTs: {len(notyet)}\\n\")\n",
    "\n",
    "    if already:\n",
    "        print(\"Processed examples (top 10):\")\n",
    "        for s in already[:10]:\n",
    "            print(f\"  {s}  (chunks={len(set(processed[s]))}, ids={sorted(set(processed[s]))[:5]}{' ...' if len(set(processed[s]))>5 else ''})\")\n",
    "        print()\n",
    "\n",
    "    if notyet:\n",
    "        print(\"Unprocessed files (top 20):\")\n",
    "        for s in notyet[:20]:\n",
    "            print(f\"  {s}\")\n",
    "        if len(notyet) > 20:\n",
    "            print(\"  ...\")\n",
    "        print()\n",
    "\n",
    "    with OUTPUT_CSV.open(\"w\", newline=\"\", encoding=\"utf-8\") as f:\n",
    "        writer = csv.writer(f)\n",
    "        writer.writerow([\"txt_stem\", \"status\", \"num_chunks\", \"chunk_ids_sorted\"])\n",
    "        for stem in sorted(all_txt_stems):\n",
    "            ids = sorted(set(processed.get(stem, [])))\n",
    "            status = \"processed\" if stem in processed else \"not_processed\"\n",
    "            writer.writerow([stem, status, len(ids), \" \".join(map(str, ids))])\n",
    "\n",
    "    print(f\"Details saved to: {OUTPUT_CSV.resolve()}\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
   ]
  }
